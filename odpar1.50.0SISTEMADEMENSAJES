class Enemy {
  constructor(dir, isBoss=false) {
    this.dir=dir; this.isBoss=isBoss; this.sizeMultiplier=isBoss?2:1;
    this.x=0; this.y=0; this.progress=0;
    this.speed=isBoss?enemySpawnConfig.boss.speed:enemySpawnConfig.normal.speed;
    const maxIndex=GRID_SIZE-(this.sizeMultiplier-1);
    if(dir==='down'){this.x=Math.floor(Math.random()*maxIndex);this.y=-(this.sizeMultiplier-1);}
    else if(dir==='up'){this.x=Math.floor(Math.random()*maxIndex);this.y=GRID_SIZE;}
    else if(dir==='right'){this.y=Math.floor(Math.random()*maxIndex);this.x=-(this.sizeMultiplier-1);}
    else{this.y=Math.floor(Math.random()*maxIndex);this.x=GRID_SIZE;}
  }
  update() {
    this.progress+=this.speed;
    if(this.dir==='down')this.y=-(this.sizeMultiplier-1)+this.progress;
    else if(this.dir==='up')this.y=GRID_SIZE-this.progress;
    else if(this.dir==='right')this.x=-(this.sizeMultiplier-1)+this.progress;
    else this.x=GRID_SIZE-this.progress;
  }
  getOccupiedCells() {
    const cells=[],cx=Math.round(this.x),cy=Math.round(this.y);
    if(this.sizeMultiplier===1)cells.push({x:cx,y:cy});
    else for(let dx=0;dx<2;dx++)for(let dy=0;dy<2;dy++)cells.push({x:cx+dx,y:cy+dy});
    return cells;
  }
  isOffScreen() {
    const margin=(this.sizeMultiplier-1)+0.8;
    if(this.dir==='down')return this.y>GRID_SIZE+margin;
    if(this.dir==='up')return this.y<-margin;
    if(this.dir==='right')return this.x>GRID_SIZE+margin;
    return this.x<-margin;
  }
  draw() {
    let offX=this.sizeMultiplier===2?CELL_SIZE/2:0, offY=this.sizeMultiplier===2?CELL_SIZE/2:0;
    const px=this.x*CELL_SIZE+CELL_SIZE/2+offX, py=this.y*CELL_SIZE+CELL_SIZE/2+offY;
    const size=this.isBoss?CELL_SIZE*1.35:CELL_SIZE*0.6;
    let angle=1;
    switch(this.dir){case'up':angle=0;break;case'right':angle=Math.PI/2;break;case'down':angle=Math.PI;break;case'left':angle=-Math.PI/2;break;}
    ctx.save(); ctx.translate(px,py); ctx.rotate(angle);
    const tipY=-size*0.85, baseY=size*0.5, baseX=size*0.65;
    ctx.beginPath(); ctx.moveTo(0,tipY); ctx.lineTo(-baseX,baseY); ctx.lineTo(baseX,baseY); ctx.closePath();
    ctx.lineWidth=this.isBoss?2.5:2; ctx.strokeStyle=this.isBoss?'#ff77ff':'#ff6644'; ctx.stroke();
    ctx.fillStyle='transparent'; ctx.fill();
    ctx.restore();
  }
}

