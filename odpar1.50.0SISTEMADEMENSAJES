function getMessageConfig(wv) {
  const cfg = MESSAGE_CONFIG;
  const def = buildDefaultConfig();
  
  // Modos alternativos
  if (cfg.mode === "sequential") {
    const txt = cfg.fallbackPool[(wv - 1) % cfg.fallbackPool.length];
    return { ...def, text: txt };
  }
  if (cfg.mode === "random") {
    const txt = cfg.fallbackPool[Math.floor(Math.random() * cfg.fallbackPool.length)];
    return { ...def, text: txt };
  }
  if (cfg.mode === "interval") {
    const im = cfg.intervalMode;
    if (wv < im.startWave) return { ...def, text: "" };
    const rel = wv - im.startWave;
    if (rel % im.every !== 0) return { ...def, text: "" };
    const pool = im.pool;
    const txt = im.poolOrder === "sequential" ?
      pool[Math.floor(rel / im.every) % pool.length] :
      pool[Math.floor(Math.random() * pool.length)];
    return { ...def, text: txt };
  }
  
  // Modo scheduled ESTRICTO
  let best = null;
  let bestPriority = -1;
  
  for (let rule of cfg.MESSAGE_SCHEDULE) {
    let priority = 0;
    let matched = false;
    
    // Comprobaciones estrictas: solo si coincide exactamente o está en rango o every
    if (rule.wave !== undefined && rule.wave === wv) {
      priority = 10;
      matched = true;
    } else if (rule.from !== undefined && rule.to !== undefined && wv >= rule.from && wv <= rule.to) {
      priority = 5;
      matched = true;
    } else if (rule.every !== undefined && rule.every > 0 && wv % rule.every === 0) {
      priority = 3;
      matched = true;
    }
    
    // Solo si hay coincidencia real, evaluamos prioridad
    if (matched && priority > bestPriority) {
      bestPriority = priority;
      best = rule;
    }
  }
  
  if (best) {
    const resolved = resolveEntry(best);
    return { ...def, ...resolved };
  }
  
  // Fallback (por defecto none)
  if (cfg.fallback === "none") return { ...def, text: "" };
  if (cfg.fallback === "random") return { ...def, text: cfg.fallbackPool[Math.floor(Math.random() * cfg.fallbackPool.length)] };
  if (cfg.fallback === "sequential") {
    const txt = cfg.fallbackPool[cfg._fallbackIndex % cfg.fallbackPool.length];
    cfg._fallbackIndex++;
    return { ...def, text: txt };
  }
  return { ...def, text: "" };
}

// ══════════════════════════════════════════════════════
// GRID HELPERS
// ══════════════════════════════════════════════════════
function getFontInfoForGrid(size) {
  if (size >= 15) return { font: FONT_5, w: 3, h: 5, gap: 2 };
  return { font: FONT_3, w: 3, h: 3, gap: 1 };
}

function wordPixelWidthFI(word, fi) {
  let width = 0;
  for (let ch of word.toUpperCase()) width += fi.w + fi.gap;
  return Math.max(0, width - fi.gap);
}

function wrapTextFI(text, maxWidth, fi) {
  const words = text.split(' ');
  const lines = [];
  let cur = '';
  
  for (let word of words) {
    const test = cur ? cur + ' ' + word : word;
    
    if (wordPixelWidthFI(test, fi) <= maxWidth) {
      cur = test; // la palabra cabe en la línea actual
    } else {
      // La palabra no cabe → guardamos la línea actual (si existe)
      if (cur) {
        lines.push(cur);
        cur = ''; //limpiamos para que no se duplique el mensaje
      }
      
      if (wordPixelWidthFI(word, fi) > maxWidth) {
        // La palabra es más larga que una línea → la troceamos carácter a carácter
        let chunk = '';
        for (let ch of word) {
          if (wordPixelWidthFI(chunk + ch, fi) <= maxWidth) {
            chunk += ch;
          } else {
            lines.push(chunk);
            chunk = ch;
          }
        }
        if (chunk) lines.push(chunk);
        // cur ya está vacío, no acumulamos nada más
      } else {
        // La palabra cabe sola en una línea → empezamos nueva línea con ella
        cur = word;
      }
    }
  }
  
  if (cur) lines.push(cur); // última línea si queda algo
  return lines;
}

function calculateGridSizeForMessage(text, mode) {
  const min = MESSAGE_CONFIG.gridMin, max = MESSAGE_CONFIG.gridMax;
  if (!text) return mode === "random" ? min + Math.floor(Math.random()*(max-min)) : min;
  let fi = getFontInfoForGrid(min);
  const words = text.split(' ');
  let maxWordW = 0;
  for (let w of words) maxWordW = Math.max(maxWordW, wordPixelWidthFI(w, fi));
  let neededWidth = maxWordW + 4;
  if (neededWidth > min) {
    fi = getFontInfoForGrid(neededWidth);
    maxWordW = 0;
    for (let w of words) maxWordW = Math.max(maxWordW, wordPixelWidthFI(w, fi));
    neededWidth = maxWordW + 4;
  }
  const lines = wrapTextFI(text, neededWidth - 2, fi);
  const blockH = lines.length * (fi.h + 1) - 1;
  const neededH = blockH + 4;
  let baseSize = Math.max(neededWidth, neededH);
  switch(mode) {
    case "expand":  baseSize = Math.ceil(baseSize * 1.2); break;
    case "compact": baseSize = Math.max(min, baseSize - 2); break;
    case "random":  baseSize = min + Math.floor(Math.random()*(max-min+1)); break;
    case "nowrap":  baseSize = Math.min(max, neededWidth); break;
    // fittext = default
  }
  return Math.max(min, Math.min(max, baseSize));
}

// ══════════════════════════════════════════════════════
// PUNTOS POR CELDA
// ══════════════════════════════════════════════════════
function calculatePointsPerCell(config, comboCount, totalCells, collectedCount, gridPos, gridSize) {
  const bp = config.basePoints || 15;
  const mode = config.pointsPerCell;
  if (typeof mode === 'number') return mode;
  switch(mode) {
    case "random": return Math.floor(Math.random()*((config.pointsRandomMax||25)-(config.pointsRandomMin||5)+1))+(config.pointsRandomMin||5);
    case "increasing": return bp + collectedCount * 2;
    case "decreasing": return bp + (totalCells - collectedCount) * 2;
    case "combo":  return Math.floor(bp * (1 + comboCount * (config.comboMultiplier||0.1)));
    case "multiplier": return Math.floor(bp * (config.multiplier||2));
    case "edge":
      if (gridPos.x===0||gridPos.x===gridSize-1||gridPos.y===0||gridPos.y===gridSize-1)
        return Math.floor(bp*(config.edgeMultiplier||2.5));
      return bp;
    case "center": {
      const cx=Math.floor(gridSize/2),cy=Math.floor(gridSize/2);
      if(Math.abs(gridPos.x-cx)<=1&&Math.abs(gridPos.y-cy)<=1) return Math.floor(bp*(config.centerMultiplier||2));
      return bp;
    }
    case "lastStand":
      if(totalCells-collectedCount<=(config.lastStandThreshold||3)) return Math.floor(bp*(config.lastStandMultiplier||5));
      return bp;
    default: return bp;
  }
}

function calculateCompletionBonus(config, totalCells, comboCount, elapsed) {
  const mode = config.completionBonus;
  const base = config.completionBonusPoints || 200;
  if (!mode || mode === 0) return 0;
  if (typeof mode === 'number') return mode;
  switch(mode) {
    case "perfect": return base;
    case "scale":   return Math.floor(base * (config.completionBonusMultiplier || 1.5));
    case "speed": {
      const factor = config.completionSpeedFactor || 0.5;
      const timeBonus = Math.max(0, base - Math.floor(elapsed / 1000) * 5);
      return timeBonus + Math.floor(base * factor);
    }
    case "overkill":
      if (comboCount >= (config.overkillThreshold || 5)) return base * 3;
      return base;
    default: return base;
  }
}

// ══════════════════════════════════════════════════════
// COORDENADAS DE MENSAJE AVANZADO
// ══════════════════════════════════════════════════════
function messageToCoordsAdvanced(message, config, gridSize) {
  const fi = getFontInfoForGrid(gridSize);
  if (!fi) return [];
  const { font, w, h, gap } = fi;
  const maxWidth = gridSize - 2;
  const lines = wrapTextFI(message, maxWidth, fi);
  const blockH = lines.length * (h + 1) - 1;
  const startY = Math.max(1, Math.floor((gridSize - blockH) / 2));
  const coords = [];
  let lineY = startY;
  for (let line of lines) {
    const lineW = wordPixelWidthFI(line, fi);
    let cx = 1 + Math.floor((maxWidth - lineW) / 2);
    for (let ch of line.toUpperCase()) {
      const matrix = font[ch] || font[' '];
      for (let row = 0; row < matrix.length; row++) {
        for (let col = 0; col < (matrix[row].length || 1); col++) {
          const bit = Array.isArray(matrix[row]) ? matrix[row][col] : matrix[row];
          if (bit === 1) {
            const x = cx + col, y = lineY + row;
            if (x >= 0 && x < gridSize && y >= 0 && y < gridSize) {
              const index = coords.length;
              const color = resolveCellColor(config, x, y, index, 0, gridSize);
              coords.push({
                x, y, color,
                strokeColor: config.strokeColor || MESSAGE_CONFIG.defaultStrokeColor,
                effects: config.effects || "none",
                effectParams: { ...(config.effectParams || {}) },
                basePoints: config.basePoints || 15,
                pointsMode: config.pointsPerCell,
                isEdge: (x===0||x===gridSize-1||y===0||y===gridSize-1),
                isCenter: Math.abs(x-Math.floor(gridSize/2))<=1 && Math.abs(y-Math.floor(gridSize/2))<=1,
              });
            }
          }
        }
      }
      cx += w + gap;
    }
    lineY += h + 1;
  }
  return coords;
}

