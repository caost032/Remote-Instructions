// DIBUJADO DE MENSAJE COLECCIONABLE (v2.0 con efectos)
// ══════════════════════════════════════════════════════
function drawMessageCollectibles() {
  const now = Date.now();
  for (let cell of messageCollectibles) {
    const px = cell.x * CELL_SIZE + CELL_SIZE / 2;
    const py = cell.y * CELL_SIZE + CELL_SIZE / 2;
    let scale = 1, alpha = 1, offsetX = 0, offsetY = 0;

    const eff = parseEffectsString(cell.effects);
    const ep = cell.effectParams || {};

    if (eff.pulseAmplitude) {
      scale += Math.sin(now * 0.003 * (eff.pulseSpeed || 0.3)) * eff.pulseAmplitude;
    }
    if (eff.chaosOffsetMax) {
      offsetX = (Math.random() - 0.5) * (ep.chaosOffsetMax || eff.chaosOffsetMax);
      offsetY = (Math.random() - 0.5) * (ep.chaosOffsetMax || eff.chaosOffsetMax);
    }
    if (eff.stealthAlphaMin !== undefined) {
      alpha = Math.sin(now * 0.002 * (eff.stealthSpeed || 0.4)) * 0.5 + 0.5;
      alpha = Math.max(eff.stealthAlphaMin, alpha);
    }
    if (eff.blinkMinAlpha !== undefined) {
      alpha = Math.sin(now * 0.006 * (eff.blinkSpeed || 0.2)) > 0 ? 1 : (eff.blinkMinAlpha || 0.3);
    }

    const s = CELL_SIZE * 0.34 * scale;
    const cellColor = cell.fillColor === "rainbow"
      ? `hsl(${(now * (cell.rainbowSpeed || 0.5) / 10 + (cell.x + cell.y) * 5) % 360},90%,55%)`
      : cell.color;

    ctx.save();
    ctx.globalAlpha = alpha;

// Glow (versión corregida: effectParams tiene prioridad absoluta)
const finalGlowRadius = ep.glowRadius !== undefined ? ep.glowRadius : eff.glowRadius;
if (finalGlowRadius > 0) {
  const gr = CELL_SIZE * finalGlowRadius * 0.4;
  const grd = ctx.createRadialGradient(px + offsetX, py + offsetY, 0, px + offsetX, py + offsetY, gr);
  
  // Obtenemos el color del glow (prioridad a effectParams)
  let rawGlowColor = ep.glowColor !== undefined ? ep.glowColor : (eff.glowColor || '#ffffff');
  
  // Convertimos cualquier formato de color a rgba seguro (evita errores con 'red', 'transparent', etc.)
  ctx.save();
  ctx.fillStyle = rawGlowColor;
  const parsedColor = ctx.fillStyle;
  ctx.restore();
  
  let safeGlowColor;
  if (parsedColor === 'transparent' || parsedColor === 'rgba(0, 0, 0, 0)') {
    safeGlowColor = 'rgba(255, 255, 255, 0)'; // totalemente transparente
  } else if (parsedColor.startsWith('rgb(')) {
    safeGlowColor = parsedColor.replace('rgb(', 'rgba(').replace(')', ', 0.53)');
  } else if (parsedColor.startsWith('#')) {
    safeGlowColor = parsedColor + '88';
  } else {
    safeGlowColor = 'rgba(255, 255, 255, 0.53)';
  }
  
  grd.addColorStop(0, safeGlowColor);
  grd.addColorStop(1, 'transparent');
  ctx.fillStyle = grd;
  ctx.beginPath();
  ctx.arc(px + offsetX, py + offsetY, gr, 0, Math.PI * 2);
  ctx.fill();
}

    // Fill
    ctx.fillStyle = cellColor || MESSAGE_CONFIG.defaultFillColor;
    ctx.beginPath(); ctx.arc(px + offsetX, py + offsetY, s, 0, Math.PI * 2); ctx.fill();
    ctx.restore();
  }
}

