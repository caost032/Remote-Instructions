  safeZone=null;safeZoneTimer=0;wasInSafeZone=false;
  bonusZone=null;bonusZoneTimer=0;
  doubleBonusZone=null;doubleBonusZoneTimer=0;lastDoubleBonusTick=0;lastDoubleBonusSpawnTime=0;evadedSinceLastDoubleBonus=0;scoreSinceLastDoubleBonus=0;
  tripleBonusZone=null;tripleBonusZoneTimer=0;lastTripleBonusTick=0;lastTripleBonusSpawnTime=0;premiumCollectedSinceLastTripleBonus=0;bossesEvadedSinceLastTripleBonus=0;
  bonusZoneCurrentWaveCount=0;doubleBonusZoneCurrentWaveCount=0;tripleBonusZoneCurrentWaveCount=0;
