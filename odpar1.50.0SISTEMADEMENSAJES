function createButton(svg){const btn=document.createElement('div');btn.className='boton';btn.innerHTML=svg;return btn;}
function createEmptyButton(){const btn=document.createElement('div');btn.className='boton vacio';return btn;}
const svgUp=`<svg viewBox="0 0 24 24"><path d="M12 5l7 8h-4v6h-6v-6H5l7-8z"/></svg>`;
const svgDown=`<svg viewBox="0 0 24 24"><path d="M12 19l-7-8h4V5h6v6h4l-7 8z"/></svg>`;
const svgLeft=`<svg viewBox="0 0 24 24"><path d="M5 12l8-7v4h6v6h-6v4l-8-7z"/></svg>`;
const svgRight=`<svg viewBox="0 0 24 24"><path d="M19 12l-8 7v-4H5v-6h6V5l8 7z"/></svg>`;
const svgUpLeft=`<svg viewBox="0 0 24 24"><path d="M6 6l12 12M6 6v8M6 6h8" stroke="#bbffff" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
const svgUpRight=`<svg viewBox="0 0 24 24"><path d="M18 6L6 18M18 6v8M18 6h-8" stroke="#bbffff" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
const svgDownLeft=`<svg viewBox="0 0 24 24"><path d="M6 18l12-12M6 18v-8M6 18h8" stroke="#bbffff" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
const svgDownRight=`<svg viewBox="0 0 24 24"><path d="M18 18L6 6M18 18v-8M18 18h-8" stroke="#bbffff" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>`;

const upLeftBtn=createButton(svgUpLeft),upBtn=createButton(svgUp),upRightBtn=createButton(svgUpRight);
const leftBtn=createButton(svgLeft),centerEmpty=createEmptyButton(),rightBtn=createButton(svgRight);
const downLeftBtn=createButton(svgDownLeft),downBtn=createButton(svgDown),downRightBtn=createButton(svgDownRight);
const centerbotones=document.getElementById('centerbotones');
centerbotones.innerHTML='';
const f1=document.createElement('section');f1.className='fila-botones';f1.appendChild(upLeftBtn);f1.appendChild(upBtn);f1.appendChild(upRightBtn);
const f2=document.createElement('section');f2.className='fila-botones';f2.appendChild(leftBtn);f2.appendChild(centerEmpty);f2.appendChild(rightBtn);
const f3=document.createElement('section');f3.className='fila-botones';f3.appendChild(downLeftBtn);f3.appendChild(downBtn);f3.appendChild(downRightBtn);
centerbotones.appendChild(f1);centerbotones.appendChild(f2);centerbotones.appendChild(f3);

const buttonMap=new Map([[upLeftBtn,'up-left'],[upBtn,'up'],[upRightBtn,'up-right'],[leftBtn,'left'],[rightBtn,'right'],[downLeftBtn,'down-left'],[downBtn,'down'],[downRightBtn,'down-right']]);

function activateButton(btn,dir){if(currentActiveBtn===btn)return;if(currentActiveBtn)currentActiveBtn.classList.remove('activo');currentActiveBtn=btn;startMove(dir);btn.classList.add('activo');}
function deactivateAll(){if(currentActiveBtn)currentActiveBtn.classList.remove('activo');currentActiveBtn=null;cancelCurrentMovement();}
function getButtonAt(x,y){const el=document.elementFromPoint(x,y);for(let[btn,dir]of buttonMap){if(btn.contains(el)||el===btn)return{btn,dir};}return null;}
function handleStart(x,y){const d=getButtonAt(x,y);if(d)activateButton(d.btn,d.dir);}
function handleMove(x,y){const d=getButtonAt(x,y);if(d)activateButton(d.btn,d.dir);else deactivateAll();}

document.addEventListener('touchstart',e=>{e.preventDefault();if(e.touches.length>0)handleStart(e.touches[e.touches.length-1].clientX,e.touches[e.touches.length-1].clientY);},{passive:false});
document.addEventListener('touchmove',e=>{e.preventDefault();if(e.touches.length>0)handleMove(e.touches[e.touches.length-1].clientX,e.touches[e.touches.length-1].clientY);},{passive:false});
document.addEventListener('touchend',e=>{if(e.touches.length===0)deactivateAll();else if(e.touches.length>0)handleStart(e.touches[e.touches.length-1].clientX,e.touches[e.touches.length-1].clientY);});
document.addEventListener('touchcancel',deactivateAll);
document.addEventListener('mousedown',e=>handleStart(e.clientX,e.clientY));
document.addEventListener('mousemove',e=>handleMove(e.clientX,e.clientY));
document.addEventListener('mouseup',deactivateAll);
document.addEventListener('keydown',e=>{
  if(gameOver){resetGame();return;}
  switch(e.key.toLowerCase()){
    case'arrowup':case'w':startMove('up');break;case'arrowdown':case's':startMove('down');break;
    case'arrowleft':case'a':startMove('left');break;case'arrowright':case'd':startMove('right');break;
    case'q':startMove('up-left');break;case'e':startMove('up-right');break;
    case'z':startMove('down-left');break;case'c':startMove('down-right');break;
  }
});

// ══════════════════════════════════════════════════════
// GAME LOOP
// ══════════════════════════════════════════════════════
let nextNormalSpawnTime = Date.now() + 4000;

function gameLoop() {
  if(!gameOver){
    for(let i=enemies.length-1;i>=0;i--){
      enemies[i].update();
      if(enemies[i].isOffScreen()){
        evadedThisWave++;evadedSinceLastDoubleBonus++;
        if(enemies[i].isBoss)bossesEvadedSinceLastTripleBonus++;
        updateUI();enemies.splice(i,1);
      }
    }
    checkEnemyCollision();updateZones();updateBonusScore();updateDoubleBonusScore();updateTripleBonusScore();updateActiveEffects();
    const now=Date.now();
    if(safeZone&&now-lastHumTime>2100&&Math.random()<0.3){playSafeZoneHum();lastHumTime=now;}
    if(now>=nextNormalSpawnTime&&!gameOver){
      let count=enemySpawnConfig.normal.baseCount+Math.floor(Math.random()*(enemySpawnConfig.normal.countVariance+1));
      for(let i=0;i<count;i++){const dirs=['down','up','left','right'];spawnEnemy(dirs[Math.floor(Math.random()*4)],false);}
      const interval=enemySpawnConfig.normal.minInterval+Math.random()*(enemySpawnConfig.normal.maxInterval-enemySpawnConfig.normal.minInterval);
      nextNormalSpawnTime=now+interval;
    }
    if(now-lastBossTime>enemySpawnConfig.boss.interval&&!gameOver){if(Math.random()<0.7)triggerBossWave();else lastBossTime=now;}
  }
  draw();requestAnimationFrame(gameLoop);
}

generateCollectibles();updateUI();updateDifficulty();gameLoop();
console.log("%cODPAR PREMIUM v2.0 – Motor de mensajes avanzado + Auto-Grid + Modificadores de oleada", "color:#FFD700;font-size:18px;font-weight:bold");
})();
</script>
