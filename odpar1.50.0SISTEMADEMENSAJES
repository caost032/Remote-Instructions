function interpolateColor(c1, c2, t) {
  const r1=parseInt(c1.slice(1,3),16),g1=parseInt(c1.slice(3,5),16),b1=parseInt(c1.slice(5,7),16);
  const r2=parseInt(c2.slice(1,3),16),g2=parseInt(c2.slice(3,5),16),b2=parseInt(c2.slice(5,7),16);
  const r=Math.round(r1+(r2-r1)*t), g=Math.round(g1+(g2-g1)*t), b=Math.round(b1+(b2-b1)*t);
  return `#${r.toString(16).padStart(2,'0')}${g.toString(16).padStart(2,'0')}${b.toString(16).padStart(2,'0')}`;
}

function resolveCellColor(config, x, y, index, totalCells, gridSize) {
  const mode = config.fillColor || "default";
  switch(mode) {
    case "random": return `hsl(${((config._seed||0)+index*37)%360},80%,60%)`;
    case "palette": {
      const pal = PALETTES[config.palette] || ["#ffffff"];
      return pal[index % pal.length];
    }
    case "rainbow": {
      const h = (Date.now()*(config.rainbowSpeed||0.5)/10 + index*5) % 360;
      return `hsl(${h},90%,55%)`;
    }
    case "gradientH": return interpolateColor(config.gradientStart, config.gradientEnd, x/(gridSize-1||1));
    case "gradientV": return interpolateColor(config.gradientStart, config.gradientEnd, y/(gridSize-1||1));
    default: return config.fillColor || MESSAGE_CONFIG.defaultFillColor;
  }
}

function parseEffectsString(str) {
  if (!str) return {};
  let combined = {};
  for (let name of str.split('+')) {
    combined = { ...combined, ...(EFFECT_PRESETS[name] || {}) };
  }
  return combined;
}

