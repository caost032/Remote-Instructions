function drawPlayer() {
  const px=playerDrawX, py=playerDrawY+Math.sin(Date.now()*0.005)*3;
  const size=CELL_SIZE*0.72, invulnerable=Date.now()<invulnerableUntil;
  const blink=invulnerable&&Math.floor(Date.now()/100)%2===0;
  let angleDiff=targetAngle-currentPlayerAngle;
  angleDiff=Math.atan2(Math.sin(angleDiff),Math.cos(angleDiff));
  currentPlayerAngle+=angleDiff*0.15;
  currentTiltX+=(targetTiltX-currentTiltX)*0.2;
  currentTiltZ+=(targetTiltZ-currentTiltZ)*0.2;
  ctx.save(); ctx.translate(px,py); ctx.rotate(currentPlayerAngle);
  ctx.transform(1,currentTiltZ*0.15,currentTiltX*0.15,1,0,0);
  if(blink)ctx.globalAlpha=0.5;
  const hasShield=activeEffects.some(e=>e.type==='shield');
  if(hasShield){ctx.beginPath();ctx.arc(0,0,size*1.1,0,Math.PI*2);ctx.fillStyle='rgba(170,221,255,0.25)';ctx.fill();ctx.strokeStyle='#aaddff';ctx.lineWidth=2.5;ctx.stroke();ctx.beginPath();ctx.arc(0,0,size*1.05,0,Math.PI*2);ctx.stroke();}
  if(activeEffects.some(e=>e.type.startsWith('magnet'))){
    const magnet=activeEffects.find(e=>e.type.startsWith('magnet'));
    const radius=POWERUP_CONFIG.types[magnet.type]?.radius||0;
    const step=CELL_SIZE*(radius>=999?2:radius*0.8);
    ctx.strokeStyle='#44ffcc';ctx.lineWidth=1.2;ctx.globalAlpha=0.3;
    ctx.beginPath();ctx.arc(0,0,step,0,Math.PI*2);ctx.stroke();
    ctx.beginPath();ctx.arc(0,0,step*0.75,0,Math.PI*2);ctx.stroke();
  }
  ctx.beginPath();ctx.moveTo(0,-size*0.85);ctx.lineTo(-size*0.55,size*0.4);ctx.lineTo(0,size*0.2);ctx.lineTo(size*0.55,size*0.4);ctx.closePath();ctx.fillStyle='transparent';ctx.fill();ctx.strokeStyle='skyblue';ctx.lineWidth=2.5;ctx.stroke();
  ctx.beginPath();ctx.moveTo(-size*0.5,size*0.1);ctx.lineTo(-size*0.95,size*0.5);ctx.lineTo(-size*0.45,size*0.5);ctx.fillStyle='transparent';ctx.fill();
  ctx.beginPath();ctx.moveTo(size*0.5,size*0.1);ctx.lineTo(size*0.95,size*0.5);ctx.lineTo(size*0.45,size*0.5);ctx.fill();
  ctx.beginPath();ctx.arc(0,-size*0.25,size*0.2,0,Math.PI*2);ctx.fillStyle='transparent';ctx.fill();ctx.strokeStyle='transparent';ctx.lineWidth=1;ctx.stroke();ctx.fillStyle='transparent';ctx.beginPath();ctx.arc(0,-size*0.28,size*0.09,0,Math.PI*2);ctx.fill();
  if(hasReviveTotem){ctx.fillStyle='#88ff88';ctx.beginPath();ctx.arc(size*0.55,-size*0.65,size*0.15,0,Math.PI*2);ctx.fill();ctx.fillStyle='#ffffff';ctx.beginPath();ctx.arc(size*0.55,-size*0.65,size*0.07,0,Math.PI*2);ctx.fill();}
  ctx.restore();
  if(playerGlow>0){ctx.fillStyle=`rgba(180,255,255,${playerGlow/45})`;ctx.beginPath();ctx.arc(px,py,CELL_SIZE*1.3,0,Math.PI*2);ctx.fill();playerGlow--;}
}

