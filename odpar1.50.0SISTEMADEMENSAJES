function startMotor() {
  if (!audioResumed || audioCtx.state !== 'running' || isMotorPlaying) return;
  try {
    motorOsc = audioCtx.createOscillator();
    motorGain = audioCtx.createGain();
    motorOsc.type = 'sawtooth';
    motorOsc.frequency.value = 10000;
    motorGain.gain.value = 0.01;
    motorOsc.connect(motorGain);
    motorGain.connect(audioCtx.destination);
    motorOsc.start();
    isMotorPlaying = true;
    if (motorInterval) clearInterval(motorInterval);
    motorInterval = setInterval(() => {
      if (!isMotorPlaying) return;
      motorOsc.frequency.linearRampToValueAtTime(25 + Math.random()*15, audioCtx.currentTime + 0.3);
    }, 2000);
  } catch(e) {}
}

function stopMotor() {
  if (!isMotorPlaying) return;
  try {
    if (motorOsc) { motorOsc.stop(); motorOsc.disconnect(); motorOsc = null; }
    if (motorGain) { motorGain.disconnect(); motorGain = null; }
    if (motorInterval) { clearInterval(motorInterval); motorInterval = null; }
  } catch(e) {}
  isMotorPlaying = false;
}

