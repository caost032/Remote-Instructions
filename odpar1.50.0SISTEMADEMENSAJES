class Particle {
  constructor(x,y,color='skyblue',sizeBoost=1) {
    this.x=x; this.y=y;
    this.vx=(Math.random()-0.5)*5; this.vy=(Math.random()-0.5)*5-2;
    this.life=30+Math.random()*20; this.alpha=1;
    this.size=(Math.random()*5+2)*sizeBoost; this.color=color; this.gravity=1;
  }
  update() { this.x+=this.vx; this.y+=this.vy; this.vy+=this.gravity; this.life--; this.alpha=Math.max(0,this.life/30); this.size*=0.96; }
  draw() { ctx.save(); ctx.globalAlpha=this.alpha; ctx.fillStyle=this.color; ctx.fillRect(this.x-this.size/2,this.y-this.size/2,this.size,this.size); ctx.restore(); }
}
class Spark {
  constructor(x,y,angle,speed) {
    this.x=x; this.y=y;
    this.vx=Math.cos(angle)*speed*(0.7+Math.random()*0.6);
    this.vy=Math.sin(angle)*speed*(0.7+Math.random()*0.6);
    this.life=16+Math.random()*12; this.alpha=1; this.length=0.5+Math.random()*5; this.width=4+Math.random()*2;
  }
  update() { this.x+=this.vx; this.y+=this.vy; this.life--; this.alpha=this.life/20; this.length*=0.92; }
  draw() {
    ctx.save(); ctx.globalAlpha=Math.max(0,this.alpha);
    ctx.translate(this.x,this.y); ctx.rotate(Math.atan2(this.vy,this.vx));
    ctx.fillStyle='#00ddff'; ctx.fillRect(-this.width/2,-this.length/2,this.width,this.length);
    ctx.fillStyle='#88ffff'; ctx.fillRect(-this.width/3,-this.length/3,this.width*0.6,this.length*0.6);
    ctx.restore();
  }
}

function createSpark(x,y,angle) { for(let i=0;i<2;i++) sparkParticles.push(new Spark(x,y,angle,4+Math.random()*3)); }
function createExplosion(x,y,count,color,sizeBoost=1) { const max=150; while(particles.length>=max) particles.shift(); for(let i=0;i<Math.min(count,30);i++) particles.push(new Particle(x,y,color,sizeBoost)); }

class FloatingText {
