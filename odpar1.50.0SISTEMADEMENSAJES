function getAvailablePowerUpTypes() {
  return Object.entries(POWERUP_CONFIG.types)
    .filter(([k,c]) => c.enabled && (!c.startWave || wave >= c.startWave))
    .map(([k]) => k);
}

function generatePowerUps() {
  powerUpsOnMap = [];
  if (wave < POWERUP_CONFIG.startWave) return;
  const candidates = getAvailablePowerUpTypes();
  if (!candidates.length) return;
  const toSpawn = Math.min(POWERUP_CONFIG.spawnCount, candidates.length);
  for (let i = 0; i < toSpawn; i++) {
    const typeKey = candidates[Math.floor(Math.random()*candidates.length)];
    let x, y, attempts = 0;
    do {
      x = Math.floor(Math.random()*GRID_SIZE);
      y = Math.floor(Math.random()*GRID_SIZE);
      attempts++;
    } while (attempts < 800 && (
      (x===player.x&&y===player.y) ||
      collectibles.some(c=>c.x===x&&c.y===y) ||
      messageCollectibles.some(c=>c.x===x&&c.y===y) ||
      powerUpsOnMap.some(p=>p.x===x&&p.y===y)
    ));
    powerUpsOnMap.push({ type: typeKey, x, y, expires: Date.now()+POWERUP_CONFIG.lifetime });
  }
}

function getPowerUpCost(type) { return POWERUP_CONFIG.types[type]?.cost || 0; }

function tryActivatePowerUp(pu) {
  const cost = getPowerUpCost(pu.type);
  if (score < cost) { createFloatingText(playerDrawX, playerDrawY-25, "SIN PUNTOS", false); playSound(320,100,'square',0.6); return false; }
  const info = POWERUP_TYPES[pu.type], cfg = POWERUP_CONFIG.types[pu.type];
  if (pu.type==='shield'&&activeEffects.some(e=>e.type==='shield')) { createFloatingText(playerDrawX,playerDrawY-25,"ESCUDO YA ACTIVO",true); playSound(400,100,'triangle',0.5); return false; }
  if (pu.type.startsWith('magnet')) {
    const existingIdx = activeEffects.findIndex(e=>e.type.startsWith('magnet'));
    if (existingIdx !== -1) {
      const existing = activeEffects[existingIdx];
      const existingRadius = POWERUP_CONFIG.types[existing.type]?.radius || 0;
      if ((cfg.radius||0) > existingRadius) { activeEffects.splice(existingIdx,1); createFloatingText(playerDrawX,playerDrawY-35,"IMÁN MEJORADO",true); }
      else { createFloatingText(playerDrawX,playerDrawY-25,"IMÁN YA ACTIVO",true); playSound(400,100,'triangle',0.5); return false; }
    }
  }
  if (pu.type==='revive'&&hasReviveTotem) { createFloatingText(playerDrawX,playerDrawY-25,"YA TIENES REVIVE",true); score+=cost; updateUI(); return false; }
  score -= cost; updateUI();
  const px=pu.x*CELL_SIZE+CELL_SIZE/2, py=pu.y*CELL_SIZE+CELL_SIZE/2;
  floatingTexts.push(new FloatingText(px,py-15,`-${cost}`,'#ff4444',false,false,false));
  if (pu.type==='revive') { hasReviveTotem=true; createFloatingText(px,py,"REVIVE LISTO",true); playSound(1350,90,'sine',0.7); }
  else if (pu.type.includes('bomb')) {
    const isLeg = pu.type==='bombLegendary';
    for(let i=enemies.length-1;i>=0;i--){ if(isLeg||Math.random()<0.8){createExplosion(enemies[i].x*CELL_SIZE+CELL_SIZE/2,enemies[i].y*CELL_SIZE+CELL_SIZE/2,isLeg?25:20,'#ff4444');enemies.splice(i,1);}}
    createExplosion(px,py,isLeg?55:40,'#ff6644',1.8);
    createFloatingText(px,py,info.name+(info.level?' '+info.level:''),true,true);
    playSound(180,350,'sawtooth',0.85);
  } else { activeEffects.push({type:pu.type,expires:Date.now()+(cfg.duration||0),radius:cfg.radius||0}); createFloatingText(px,py,info.name+(info.level?' '+info.level:''),true); }
  powerUpsOnMap = powerUpsOnMap.filter(p=>p!==pu);
  return true;
}

function updateActiveEffects() {
  const now = Date.now();
  for(let i=activeEffects.length-1;i>=0;i--) if(now>=activeEffects[i].expires) activeEffects.splice(i,1);
}

function drawPowerUpsOnMap() {
  const now = Date.now();
  for(let pu of powerUpsOnMap) {
    if(now>pu.expires) continue;
    const px=pu.x*CELL_SIZE+CELL_SIZE/2, py=pu.y*CELL_SIZE+CELL_SIZE/2;
    const pulse=Math.sin(now/110)*0.07+1.0, info=POWERUP_TYPES[pu.type];
    ctx.save(); ctx.strokeStyle=info.color; ctx.lineWidth=2.0;
    const s=CELL_SIZE*0.42*pulse;
    if(pu.type.startsWith('magnet')){ctx.beginPath();ctx.moveTo(px,py-s);ctx.lineTo(px-s*0.75,py+s*0.65);ctx.lineTo(px+s*0.75,py+s*0.65);ctx.closePath();ctx.stroke();}
    else if(pu.type==='shield'){ctx.beginPath();ctx.arc(px,py,s*1.15,0,Math.PI*2);ctx.stroke();ctx.lineWidth=1.6;ctx.beginPath();ctx.arc(px,py,s*0.7,0,Math.PI*2);ctx.stroke();}
    else if(pu.type.includes('bomb')){ctx.beginPath();ctx.arc(px,py,s,0,Math.PI*2);ctx.stroke();}
    else if(pu.type==='revive'){ctx.lineWidth=2.4;ctx.beginPath();ctx.moveTo(px-s*0.8,py-s);ctx.lineTo(px+s*0.8,py-s);ctx.moveTo(px,py-s*1.1);ctx.lineTo(px,py+s*1.1);ctx.stroke();}
    else if(pu.type==='speed'){ctx.lineWidth=2.4;ctx.beginPath();ctx.moveTo(px,py-s*1.2);ctx.lineTo(px,py+s*0.8);ctx.moveTo(px-s*0.7,py-s*0.4);ctx.lineTo(px+s*0.7,py-s*0.4);ctx.stroke();}
    ctx.font='900 14px "Press Start 2P",monospace';ctx.fillStyle='#ffffff';ctx.textAlign='center';ctx.textBaseline='top';
    ctx.fillText(getPowerUpCost(pu.type),px,py+s*1.2);
    ctx.restore();
  }
}

