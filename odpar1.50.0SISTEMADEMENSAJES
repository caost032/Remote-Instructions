#highScore { color: #ffd700; text-shadow: 0 0 6px #ff0; }
#waveSpan { color: #0ff; text-shadow: 0 0 5px #0ff; }
#evadedSpan { color: #88ff88; text-shadow: 0 0 5px #0f0; }
#msgSpan { color: #ff88ff; text-shadow: 0 0 5px #f0f; font-size: 0.85em; }
.botones { width: 100%; max-width: 560px; height: 50%; background: transparent; display: flex; justify-content: center; align-items: center; padding: 5px; }
.centerbotones { display: flex; flex-direction: column; justify-content: center; align-items: center; width: 100%; height: 100%; max-width: 400px; gap: 3%; }
.fila-botones { display: flex; justify-content: center; align-items: center; width: 100%; height: 30%; gap: 4%; background: transparent; }
.boton { display: flex; justify-content: center; align-items: center; width: 28%; height: 100%; background: #0a0f1a; border-bottom: solid lightcyan 8px; border-radius: 20%; box-shadow: 0 4px 8px rgba(0,0,0,0.5); transition: all 0.05s linear; cursor: pointer; touch-action: manipulation; -webkit-touch-callout: none; }
.boton.activo { transform: translateY(4px); border-bottom-width: 4px; box-shadow: 0 1px 2px rgba(0,0,0,0.5); background: #1a2a3a; }
.boton svg { width: 65%; height: 65%; fill: #bbffff; filter: drop-shadow(0 2px 2px rgba(0,0,0,0.5)); pointer-events: none; }
.boton.vacio { background: transparent; border: none; box-shadow: none; pointer-events: none; cursor: default; }
.boton.vacio svg { display: none; }
@media (max-width: 550px) {
