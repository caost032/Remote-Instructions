// ══════════════════════════════════════════════════════
// GLITCH
// ══════════════════════════════════════════════════════
function drawGlitchEffect() {
  if(!glitchActive||glitchTimer<=0)return;
  glitchTimer--;const intensity=glitchIntensity*(glitchTimer/2);
  ctx.save();ctx.globalAlpha=intensity*1;
  for(let i=0;i<6;i++){const offset=(Math.random()-0.5)*18*intensity;const sliceY=Math.random()*canvas.height;const sliceH=8+Math.random()*22;ctx.drawImage(canvas,0,sliceY,canvas.width,sliceH,offset,sliceY,canvas.width,sliceH);}
  if(Math.random()<0.4){ctx.fillStyle=Math.random()<0.1?'#00ffff':'#ff00ff';ctx.fillRect(0,0,canvas.width,canvas.height);}
  ctx.restore();if(glitchTimer<=0){glitchActive=false;glitchIntensity=0;}
}

// ══════════════════════════════════════════════════════
// DRAW
// ══════════════════════════════════════════════════════
function draw() {
  const grad=ctx.createRadialGradient(canvas.width/2,canvas.height/2,80,canvas.width/2,canvas.height/2,canvas.width/1.5);
  grad.addColorStop(0,'#0a1428');grad.addColorStop(1,'#03060c');
  ctx.fillStyle=grad;ctx.fillRect(0,0,canvas.width,canvas.height);
  if(premiumFlash>0){ctx.fillStyle=`rgba(255,0,255,${Math.min(0.35,premiumFlash/45)})`;ctx.fillRect(0,0,canvas.width,canvas.height);premiumFlash--;}
  ctx.save();ctx.strokeStyle='rgba(255,255,255,0.05)';ctx.lineWidth=1;
  for(let i=0;i<=GRID_SIZE;i++){let pos=i*CELL_SIZE;ctx.beginPath();ctx.moveTo(pos,0);ctx.lineTo(pos,canvas.height);ctx.stroke();ctx.beginPath();ctx.moveTo(0,pos);ctx.lineTo(canvas.width,pos);ctx.stroke();}
  ctx.restore();
  drawSafeZone();drawBonusZone();drawDoubleBonusZone();drawTripleBonusZone();
  drawPowerUpsOnMap();
  for(let c of collectibles){const px=c.x*CELL_SIZE+CELL_SIZE/2,py=c.y*CELL_SIZE+CELL_SIZE/2;ctx.fillStyle='#ffcc33';ctx.beginPath();ctx.arc(px,py,CELL_SIZE*0.33,0,Math.PI*2);ctx.fill();}
  drawMessageCollectibles();
  for(let e of enemies) e.draw();
  drawWallAlerts();
  for(let i=particles.length-1;i>=0;i--){particles[i].update();particles[i].draw();if(particles[i].life<=0)particles.splice(i,1);}
  for(let i=sparkParticles.length-1;i>=0;i--){sparkParticles[i].update();sparkParticles[i].draw();if(sparkParticles[i].life<=0)sparkParticles.splice(i,1);}
  drawPlayer();
  drawActiveEffectsHUD();
  for(let i=floatingTexts.length-1;i>=0;i--){floatingTexts[i].update();floatingTexts[i].draw();if(floatingTexts[i].life<=0)floatingTexts.splice(i,1);}
  if(!moving){drawGlitchEffect();playerDrawX=player.x*CELL_SIZE+CELL_SIZE/2;playerDrawY=player.y*CELL_SIZE+CELL_SIZE/2;}
  if(gameOver){
    ctx.fillStyle='rgba(0,0,0,0.85)';ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.font='900 42px "Press Start 2P",monospace';ctx.fillStyle='#ff4466';ctx.textAlign='center';
    ctx.fillText('GAME OVER',canvas.width/2,canvas.height/2-40);
    ctx.font='18px "Press Start 2P",monospace';ctx.fillStyle='#ffffff';
    ctx.fillText('Toca cualquier botón',canvas.width/2,canvas.height/2+20);
    ctx.fillText('para REINICIAR',canvas.width/2,canvas.height/2+55);
  }
}

