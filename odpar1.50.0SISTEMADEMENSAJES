function adjustZonesToNewGrid(oldSize, newSize) {
  [safeZone, bonusZone, doubleBonusZone, tripleBonusZone].forEach(zone => {
    if (zone) {
      zone.x = Math.min(newSize-1, Math.floor(zone.x * newSize / oldSize));
      zone.y = Math.min(newSize-1, Math.floor(zone.y * newSize / oldSize));
    }
  });
}

function generateSafeZone() {
  if (safeZoneDisabledForWave) return;
  safeZone = { x: Math.floor(Math.random()*GRID_SIZE), y: Math.floor(Math.random()*GRID_SIZE), expires: Date.now()+SAFE_ZONE_DURATION };
}
function generateBonusZone() {
  bonusZone = { x: Math.floor(Math.random()*GRID_SIZE), y: Math.floor(Math.random()*GRID_SIZE), expires: Date.now()+BONUS_ZONE_DURATION };
  lastBonusTick = Date.now();
}
function generateDoubleBonusZone() {
