  const secs=Math.ceil(timeLeft/1000), pulse=Math.sin(Date.now()/45)*0.2+0.85;
  ctx.save();
  ctx.globalAlpha=0.6*ratio; ctx.fillStyle='#FFD700';
  ctx.beginPath(); ctx.arc(px,py,CELL_SIZE*0.82*pulse,0,Math.PI*2); ctx.fill();
