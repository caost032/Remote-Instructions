function addWallAlert(dir,isBoss,coord,delay){wallAlerts.push({dir,isBoss,coord,expiryTime:Date.now()+delay});}
function drawWallAlerts() {
  const now=Date.now();
  for(let i=wallAlerts.length-1;i>=0;i--){
    const a=wallAlerts[i];if(now>=a.expiryTime){wallAlerts.splice(i,1);continue;}
    const remaining=(a.expiryTime-now)/(a.isBoss?enemySpawnConfig.boss.alertTimeMs:enemySpawnConfig.normal.alertTimeMs);
    const alpha=Math.min(0.95,remaining*0.9+0.2);
    ctx.save();ctx.globalAlpha=alpha;ctx.strokeStyle=a.isBoss?'#ff66ff':'#ffff44';ctx.lineWidth=a.isBoss?9:6;
    if(a.dir==='down'){const x=a.coord*CELL_SIZE+CELL_SIZE/2;ctx.beginPath();ctx.moveTo(x-CELL_SIZE*1.8,20);ctx.lineTo(x+CELL_SIZE*1.8,20);ctx.stroke();}
    else if(a.dir==='up'){const x=a.coord*CELL_SIZE+CELL_SIZE/2;ctx.beginPath();ctx.moveTo(x-CELL_SIZE*1.8,canvas.height-20);ctx.lineTo(x+CELL_SIZE*1.8,canvas.height-20);ctx.stroke();}
    else if(a.dir==='left'){const y=a.coord*CELL_SIZE+CELL_SIZE/2;ctx.beginPath();ctx.moveTo(canvas.width-20,y-CELL_SIZE*1.8);ctx.lineTo(canvas.width-20,y+CELL_SIZE*1.8);ctx.stroke();}
    else if(a.dir==='right'){const y=a.coord*CELL_SIZE+CELL_SIZE/2;ctx.beginPath();ctx.moveTo(20,y-CELL_SIZE*1.8);ctx.lineTo(20,y+CELL_SIZE*1.8);ctx.stroke();}
    if(a.isBoss){ctx.fillStyle='#ff66ff';ctx.font='bold 22px "Press Start 2P",monospace';ctx.fillText('⚠ BOSS ⚠',canvas.width/2,48);}
    ctx.restore();
  }
}

function spawnEnemy(dir,isBoss=false) {
  let coord,enemy;const size=isBoss?2:1,maxIndex=GRID_SIZE-(size-1);
  if(dir==='down'){coord=Math.floor(Math.random()*maxIndex);enemy=new Enemy(dir,isBoss);enemy.x=coord;enemy.y=-(size-1);}
  else if(dir==='up'){coord=Math.floor(Math.random()*maxIndex);enemy=new Enemy(dir,isBoss);enemy.x=coord;enemy.y=GRID_SIZE;}
  else if(dir==='right'){coord=Math.floor(Math.random()*maxIndex);enemy=new Enemy(dir,isBoss);enemy.x=-(size-1);enemy.y=coord;}
  else{coord=Math.floor(Math.random()*maxIndex);enemy=new Enemy(dir,isBoss);enemy.x=GRID_SIZE;enemy.y=coord;}
  const delay=isBoss?enemySpawnConfig.boss.alertTimeMs:enemySpawnConfig.normal.alertTimeMs;
  if(isBoss){addWallAlert(dir,true,coord,delay);addWallAlert(dir,true,coord+1,delay);}
  else addWallAlert(dir,false,coord,delay);
  registerTimeout(()=>{if(!gameOver)enemies.push(enemy);},delay);
}

function triggerBossWave() {
  if(gameOver)return;lastBossTime=Date.now();
  const dirs=['down','up','left','right'];
  dirs.forEach((d,idx)=>registerTimeout(()=>{if(!gameOver)spawnEnemy(d,true);},idx*380));
}

// ══════════════════════════════════════════════════════
// COLISIÓN
// ══════════════════════════════════════════════════════
function checkEnemyCollision() {
  if(isInSafeZone()||Date.now()<invulnerableUntil)return false;
  for(let e of enemies){
    const cells=e.getOccupiedCells();
    for(let cell of cells){
      if(cell.x<0||cell.x>=GRID_SIZE||cell.y<0||cell.y>=GRID_SIZE)continue;
      if(player.x===cell.x&&player.y===cell.y){
        if(hasReviveTotem){hasReviveTotem=false;enemies=[];createExplosion(playerDrawX,playerDrawY,50,'#88ff88',2.2);createFloatingText(canvas.width/2,canvas.height/2-50,"REVIVIDO",true,true);invulnerableUntil=Date.now()+1500;return false;}
        const shieldIdx=activeEffects.findIndex(ef=>ef.type==='shield');
        if(shieldIdx!==-1){activeEffects.splice(shieldIdx,1);const idx=enemies.indexOf(e);if(idx!==-1){createExplosion(e.x*CELL_SIZE+CELL_SIZE/2,e.y*CELL_SIZE+CELL_SIZE/2,25,'#aaddff');enemies.splice(idx,1);}createFloatingText(playerDrawX,playerDrawY-20,"ESCUDO ROTO",true);playSound(800,120,'triangle',0.5);invulnerableUntil=Date.now()+800;return false;}
        gameOver=true;stopMotor();createExplosion(player.x*CELL_SIZE+CELL_SIZE/2,player.y*CELL_SIZE+CELL_SIZE/2,50,'#ff0000',1.5);playHitSound();return true;
      }
    }
  }
  return false;
}

// ══════════════════════════════════════════════════════
// GENERACIÓN DE COLECCIONABLES
// ══════════════════════════════════════════════════════
function generateCollectibles() {
  collectibles = [];
  messageCollectibles = [];
  const normalCount = Math.max(3, Math.floor(GRID_SIZE * 0.1));
  for(let i=0;i<normalCount;i++){
    let x,y,attempts=0;
    do{x=Math.floor(Math.random()*GRID_SIZE);y=Math.floor(Math.random()*GRID_SIZE);attempts++;}
    while(attempts<800&&((x===player.x&&y===player.y)||collectibles.some(c=>c.x===x&&c.y===y)));
    if(attempts<800)collectibles.push({x,y});
  }
  if (currentWaveMessage && GRID_SIZE >= 8) {
    const coords = messageToCoordsAdvanced(currentWaveMessage, currentWaveConfig, GRID_SIZE);
    for(let c of coords){
      if(c.x>=0&&c.x<GRID_SIZE&&c.y>=0&&c.y<GRID_SIZE&&!(c.x===player.x&&c.y===player.y)){
        if(!collectibles.some(p=>p.x===c.x&&p.y===c.y)&&!powerUpsOnMap.some(p=>p.x===c.x&&p.y===c.y))
          messageCollectibles.push(c);
      }
    }
  }
}

