// ══════════════════════════════════════════════════════
// MOVER CELDA HACIA JUGADOR (con step para legendario)
// ══════════════════════════════════════════════════════
function moveCellTowardsPlayer(cell, magnetRadius) {
  const step = magnetRadius >= 999 ? 2 : 1;
  cell.x += Math.sign(player.x - cell.x) * step;
  cell.y += Math.sign(player.y - cell.y) * step;
}

// ══════════════════════════════════════════════════════
// CHECK COLECCIONABLES (v2.0)
// ══════════════════════════════════════════════════════
function checkCollectibles() {
  let magnetRadius = 0;
  for(let ef of activeEffects)
    if(ef.type.startsWith('magnet')&&(POWERUP_CONFIG.types[ef.type]?.radius||0)>magnetRadius)
      magnetRadius = POWERUP_CONFIG.types[ef.type].radius||0;

  function inRange(cx,cy){
    if(magnetRadius===0)return(cx===player.x&&cy===player.y);
    const dx=Math.abs(cx-player.x),dy=Math.abs(cy-player.y);
    if(magnetRadius>=999)return dx<=GRID_SIZE&&dy<=GRID_SIZE;
    return dx<=magnetRadius&&dy<=magnetRadius;
  }

  // Coleccionables normales
  for(let i=collectibles.length-1;i>=0;i--){
    if(inRange(collectibles[i].x,collectibles[i].y)){
      if(magnetRadius>0&&(collectibles[i].x!==player.x||collectibles[i].y!==player.y)){
        moveCellTowardsPlayer(collectibles[i],magnetRadius);
      }
      if(collectibles[i].x===player.x&&collectibles[i].y===player.y){
        let pts = doublePointsActive ? 16 : 8;
        score+=pts; scoreSinceLastDoubleBonus+=pts;
        createExplosion(player.x*CELL_SIZE+CELL_SIZE/2,player.y*CELL_SIZE+CELL_SIZE/2,15,'#ffd700');
        createFloatingText(player.x*CELL_SIZE+CELL_SIZE/2,player.y*CELL_SIZE+CELL_SIZE/2,pts);
        playNormalCollect();
        collectibles.splice(i,1);
        if(score>highScore){highScore=score;localStorage.setItem('odparHighScore',highScore);}
        updateUI();
        if(collectibles.length===0)completeWave();
        return;
      }
    }
  }

  // Celdas del mensaje
  for(let i=messageCollectibles.length-1;i>=0;i--){
    const cell = messageCollectibles[i];
    if(inRange(cell.x,cell.y)){
      if(magnetRadius>0&&(cell.x!==player.x||cell.y!==player.y)){
        moveCellTowardsPlayer(cell,magnetRadius);
      }
      if(cell.x===player.x&&cell.y===player.y){
        const totalCells = messageCollectibles.length + 1;
        const collectedCount = totalCells - messageCollectibles.length;
        let pts = calculatePointsPerCell(currentWaveConfig, comboCount, totalCells, collectedCount, {x:cell.x,y:cell.y}, GRID_SIZE);
        if(doublePointsActive) pts *= 2;
        score+=pts; scoreSinceLastDoubleBonus+=pts;
        premiumCollectedSinceLastTripleBonus++;
        createExplosion(player.x*CELL_SIZE+CELL_SIZE/2,player.y*CELL_SIZE+CELL_SIZE/2,20,'#ff88ff');
        createFloatingText(player.x*CELL_SIZE+CELL_SIZE/2,player.y*CELL_SIZE+CELL_SIZE/2,pts,true);
        playPremiumCollect();
        messageCollectibles.splice(i,1);
        comboCount++;
        if(score>highScore){highScore=score;localStorage.setItem('odparHighScore',highScore);}
        updateUI();

        if(messageCollectibles.length===0&&currentWaveMessage){
          const elapsed = Date.now() - waveStartTime;
          let bonus = calculateCompletionBonus(currentWaveConfig, totalCells, comboCount, elapsed);
          if(doublePointsActive) bonus *= 2;
          if(currentWaveConfig.bonusOnCompleteEnabled!==false&&bonus>0){
            score+=bonus;
            if(score>highScore){highScore=score;localStorage.setItem('odparHighScore',highScore);}
            createExplosion(canvas.width/2,canvas.height/2,50,'#ffd700',2.5);
            floatingTexts.push(new FloatingText(canvas.width/2,canvas.height/2-40,`¡MSG COMPLETO! +${bonus}`,'#FFD700',true,true,true));
            playTripleBonusCollect();
            updateUI();
          }
        }
        return;
      }
    }
  }

  // Power-ups
  for(let i=powerUpsOnMap.length-1;i>=0;i--){
    if(powerUpsOnMap[i].x===player.x&&powerUpsOnMap[i].y===player.y){ tryActivatePowerUp(powerUpsOnMap[i]); return; }
  }
}

// ══════════════════════════════════════════════════════
// COMPLETE WAVE (v2.0)
// ══════════════════════════════════════════════════════
function completeWave() {
  if(gameOver)return;
  playLevelComplete();
  wave++; evadedThisWave=0; comboCount=0;
  waveStartTime = Date.now();

  // 1. Obtener config de oleada
  currentWaveConfig = getMessageConfig(wave);
  currentWaveMessage = currentWaveConfig.text;

  // 2. Dificultad base + modificadores
  updateDifficulty();
  applyOleadaModifiers(currentWaveConfig);

  // 3. Calcular nuevo grid
  const oldSize = GRID_SIZE;
  let newSize;
  if(wave > 1){
    if(MESSAGE_CONFIG.autoGrid && currentWaveMessage){
      newSize = calculateGridSizeForMessage(currentWaveMessage, currentWaveConfig.mapSizeMode || "fittext");
      // Añadir algo de variación si el mensaje es muy corto
      if(newSize < 18 && Math.random()<0.5) newSize += Math.floor(Math.random()*5);
    } else {
      newSize = (wave%5===0) ? 20+Math.floor(Math.random()*11) : 10+Math.floor(Math.random()*11);
    }
    newSize = Math.max(MESSAGE_CONFIG.gridMin, Math.min(MESSAGE_CONFIG.gridMax, newSize));
  } else {
    newSize = INITIAL_GRID_SIZE;
  }
  GRID_SIZE = newSize;

  // 4. Ajustar zonas ANTES de resize
  adjustZonesToNewGrid(oldSize, newSize);

  // 5. Resize (zonas conservadas)
  resizeGameElements();
  playerDrawX = player.x*CELL_SIZE+CELL_SIZE/2;
  playerDrawY = player.y*CELL_SIZE+CELL_SIZE/2;

  // 6. Efectos visuales
  glitchActive=true; glitchTimer=40; glitchIntensity=currentWaveConfig.glitchIntensity||1;
  playerGlow = currentWaveConfig.playerGlowOnStart||50;
  createExplosion(playerDrawX,playerDrawY,55,'#00ffff',2.0);
  createExplosion(playerDrawX,playerDrawY,35,'#ffffff',1.4);
  createFloatingText(playerDrawX,playerDrawY-65,`¡GRID: ${GRID_SIZE}!`,false,false);
  playSound(1200,80,'sine',0.6); setTimeout(()=>playSound(1800,120,'sawtooth',0.5),80);

  bonusZoneCurrentWaveCount=0; doubleBonusZoneCurrentWaveCount=0; tripleBonusZoneCurrentWaveCount=0;
  updateUI();
  createWaveCompleteText(wave-1);
  generatePowerUps();

  registerTimeout(()=>{
    if(!gameOver){
      if(!safeZone&&!safeZoneDisabledForWave) generateSafeZone();
      if(Math.random()<0.45||(Date.now()-lastBossTime>enemySpawnConfig.boss.interval)) triggerBossWave();
    }
  },500);
}

// ══════════════════════════════════════════════════════
// MOVIMIENTO
// ══════════════════════════════════════════════════════
function executeMove(dir) {
  let newX=player.x, newY=player.y;
  switch(dir){
    case'up':newY--;break;case'down':newY++;break;case'left':newX--;break;case'right':newX++;break;
    case'up-left':newX--;newY--;break;case'up-right':newX++;newY--;break;
    case'down-left':newX--;newY++;break;case'down-right':newX++;newY++;break;
  }
  if(newX<0||newX>=GRID_SIZE||newY<0||newY>=GRID_SIZE)return false;
  moving=true;
  let startX=playerDrawX,startY=playerDrawY,endX=newX*CELL_SIZE+CELL_SIZE/2,endY=newY*CELL_SIZE+CELL_SIZE/2;
  player.x=newX; player.y=newY;
  const speedActive=activeEffects.some(e=>e.type==='speed');
  let duration=Math.max(MIN_MOVE_DELAY,speedActive?currentMoveDelay/2:currentMoveDelay);
  let animStart=performance.now();
  function easeInOutCubic(t){return t<0.5?4*t*t*t:1-Math.pow(-2*t+2,3)/2;}
  function animateMove(now){
    let elapsed=now-animStart,t=Math.min(1,elapsed/duration),ease=easeInOutCubic(t);
    playerDrawX=startX+(endX-startX)*ease;playerDrawY=startY+(endY-startY)*ease;
    if(t<1)requestAnimationFrame(animateMove);
    else{playerDrawX=endX;playerDrawY=endY;moving=false;lastMoveTimestamp=performance.now();if(currentMoveDelay>MIN_MOVE_DELAY)currentMoveDelay=Math.max(MIN_MOVE_DELAY,currentMoveDelay*0.9);startNextMove();}
  }
  requestAnimationFrame(animateMove);
  playMoveSound(); startMotor();
  const tiltMap={up:[-0.3,0],down:[0.3,0],left:[0,-0.4],right:[0,0.4],'up-left':[-0.2,-0.3],'up-right':[-0.2,0.3],'down-left':[0.2,-0.3],'down-right':[0.2,0.3]};
  const [tx,tz]=tiltMap[dir]||[0,0];targetTiltX=tx;targetTiltZ=tz;
  setTimeout(()=>{targetTiltX=0;targetTiltZ=0;},200);
  if(rotationResetTimer)clearTimeout(rotationResetTimer);
  const rotMap={up:'rotateX(48deg)',down:'rotateX(35deg)',left:'rotateX(40deg) rotateY(-8deg)',right:'rotateX(40deg) rotateY(8deg)','up-left':'rotateX(46deg) rotateY(-7deg)','up-right':'rotateX(46deg) rotateY(7deg)','down-left':'rotateX(37deg) rotateY(-7deg)','down-right':'rotateX(37deg) rotateY(7deg)'};
  canvas.style.transform=rotMap[dir]||'rotateX(40deg)';
  rotationResetTimer=setTimeout(()=>{canvas.style.transform='rotateX(40deg)';},200);
  const angleMap={up:0,right:Math.PI/2,down:Math.PI,left:-Math.PI/2,'up-right':Math.PI/4,'up-left':-Math.PI/4,'down-right':3*Math.PI/4,'down-left':-3*Math.PI/4};
  targetAngle=angleMap[dir]||0;
  const backAngleMap={up:Math.PI/2,down:-Math.PI/2,left:0,right:Math.PI,'up-right':-3*Math.PI/4,'up-left':3*Math.PI/4,'down-right':-Math.PI/4,'down-left':Math.PI/4};
  let backAngle=backAngleMap[dir]||0;
  for(let i=0;i<6;i++){let offX=(Math.random()-0.5)*12,offY=(Math.random()-0.5)*12;createSpark(playerDrawX+offX,playerDrawY+offY,backAngle+(Math.random()-0.5)*0.8);}
  const nowInSafe=isInSafeZone();
  if(nowInSafe&&!wasInSafeZone){playSafeZoneEnter();createExplosion(player.x*CELL_SIZE+CELL_SIZE/2,player.y*CELL_SIZE+CELL_SIZE/2,20,'#00ffcc',1.2);}
  wasInSafeZone=nowInSafe;
  checkCollectibles();
  return true;
}

function startNextMove(){if(moving||gameOver)return;let nextDir=pendingDirection||currentDirection;if(!nextDir)return;pendingDirection=null;if(currentDirection!==nextDir)currentMoveDelay=110;currentDirection=nextDir;executeMove(currentDirection);}
function startMove(dir){if(gameOver){resetGame();return;}if(moving){pendingDirection=dir;return;}if(currentDirection!==dir)currentMoveDelay=110;currentDirection=dir;executeMove(dir);}
function cancelCurrentMovement(){if(moving)pendingDirection=null;currentDirection=null;pendingDirection=null;stopMotor();currentMoveDelay=110;}

// ══════════════════════════════════════════════════════
// RESET
// ══════════════════════════════════════════════════════
function resetGame() {
