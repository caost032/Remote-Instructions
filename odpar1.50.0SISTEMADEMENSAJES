}

function updateZones() {
  if (!safeZone){safeZoneTimer++;if(safeZoneTimer>130&&!safeZoneDisabledForWave){generateSafeZone();safeZoneTimer=0;}}
  else if(Date.now()>=safeZone.expires)safeZone=null;
  if(!bonusZone){bonusZoneTimer++;if(bonusZoneTimer>200&&bonusZoneCurrentWaveCount<MAX_BONUS_ZONES_PER_WAVE){generateBonusZone();bonusZoneCurrentWaveCount++;bonusZoneTimer=0;}}
  else if(Date.now()>=bonusZone.expires)bonusZone=null;
  if(!doubleBonusZone){doubleBonusZoneTimer++;if(doubleBonusZoneCurrentWaveCount<MAX_DOUBLE_BONUS_ZONES_PER_WAVE&&doubleBonusZoneTimer>180&&Math.random()<0.25&&Date.now()-lastDoubleBonusSpawnTime>=10000&&evadedSinceLastDoubleBonus>8&&scoreSinceLastDoubleBonus>150){generateDoubleBonusZone();doubleBonusZoneCurrentWaveCount++;doubleBonusZoneTimer=0;lastDoubleBonusSpawnTime=Date.now();evadedSinceLastDoubleBonus=0;scoreSinceLastDoubleBonus=0;}}
  else if(Date.now()>=doubleBonusZone.expires)doubleBonusZone=null;
  if(!tripleBonusZone){tripleBonusZoneTimer++;if(tripleBonusZoneCurrentWaveCount<MAX_TRIPLE_BONUS_ZONES_PER_WAVE&&tripleBonusZoneTimer>250&&Math.random()<0.05&&Date.now()-lastTripleBonusSpawnTime>=20000&&premiumCollectedSinceLastTripleBonus>=3&&bossesEvadedSinceLastTripleBonus>=2&&!doubleBonusZone){generateTripleBonusZone();tripleBonusZoneCurrentWaveCount++;tripleBonusZoneTimer=0;lastTripleBonusSpawnTime=Date.now();premiumCollectedSinceLastTripleBonus=0;bossesEvadedSinceLastTripleBonus=0;}}
  else if(Date.now()>=tripleBonusZone.expires)tripleBonusZone=null;
}

function isInSafeZone(){return safeZone&&player.x===safeZone.x&&player.y===safeZone.y;}
function isInBonusZone(){return bonusZone&&player.x===bonusZone.x&&player.y===bonusZone.y;}
function isInDoubleBonusZone(){return doubleBonusZone&&player.x===doubleBonusZone.x&&player.y===doubleBonusZone.y;}
function isInTripleBonusZone(){return tripleBonusZone&&player.x===tripleBonusZone.x&&player.y===tripleBonusZone.y;}

function drawZoneArc(zone, duration, fillFill, strokeFill, outerRadius, innerRadius, pulseDiv) {
  if (!zone) return;
  const px=zone.x*CELL_SIZE+CELL_SIZE/2, py=zone.y*CELL_SIZE+CELL_SIZE/2;
  const timeLeft=Math.max(0,zone.expires-Date.now()), ratio=timeLeft/duration;
  const secs=Math.ceil(timeLeft/1000), pulse=Math.sin(Date.now()/pulseDiv)*0.15+0.88;
  ctx.save();
  ctx.globalAlpha=0.5*ratio; ctx.fillStyle=fillFill;
  ctx.beginPath(); ctx.arc(px,py,CELL_SIZE*outerRadius*pulse,0,Math.PI*2); ctx.fill();
  ctx.globalAlpha=0.8; ctx.strokeStyle='#ffffff'; ctx.lineWidth=4;
  ctx.beginPath(); ctx.arc(px,py,CELL_SIZE*0.68,0,Math.PI*2); ctx.stroke();
  ctx.fillStyle=strokeFill;
  ctx.beginPath(); ctx.arc(px,py,CELL_SIZE*innerRadius,0,Math.PI*2); ctx.fill();
  ctx.font='900 28px "Press Start 2P",monospace'; ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillStyle='#ffffff'; ctx.strokeStyle='#003344'; ctx.lineWidth=3;
  ctx.strokeText(secs,px,py); ctx.fillText(secs,px,py);
  ctx.restore();
}

function drawSafeZone() { drawZoneArc(safeZone,SAFE_ZONE_DURATION,'#00ffcc','#00ffff',0.75,0.45,70); }
function drawBonusZone() { drawZoneArc(bonusZone,BONUS_ZONE_DURATION,'#ffcc00','#ffaa00',0.75,0.45,60); }
function drawDoubleBonusZone() { drawZoneArc(doubleBonusZone,DOUBLE_BONUS_ZONE_DURATION,'#ff00ff','#cc00cc',0.78,0.48,55); }
